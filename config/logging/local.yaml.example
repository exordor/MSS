# Local logging configuration override template
# Copy this file as local.yaml and modify as needed
# Usage: ./run_ros2_camera.sh --log-config config/logging/local.yaml

default_profile: dev

profiles:
  # Custom local development configuration
  local:
    rcutils:
      use_stdout: 1
      colorized_output: 1
      console_output_format: '[{time}] [{severity}] [{name}] {message}'
      buffered_stream: 0
      log_level: debug
    python:
      unbuffered: 1
      verbose: 0
