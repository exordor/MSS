<?xml version="1.0"?>
<launch>
    <!-- Enable / disable rosbag -->
    <arg name="record" default="true" />
    <arg name="bag_dir" default="$(find ros1_bringup)/../../../temp" />
    <arg name="bag_name" default="all_sensors" />

    <!-- Bringup: Camera -->
    <group>
        <include file="$(find ros1_bringup)/launch/camera.launch" />
    </group>

    <!-- Bringup: IMU -->
    <group>
        <include file="$(find ros1_bringup)/launch/imu.launch" />
    </group>

    <!-- Bringup: LiDAR -->
    <group>
        <include file="$(find ros1_bringup)/launch/navi_lidar.launch" />
    </group>

    <!-- Rosbag Recording -->
    <group if="$(arg record)">
      <node pkg="rosbag" type="record" name="rosbag_record" output="screen"
          args="record -o $(arg bag_dir)/$(arg bag_name)
                /navi_lidar/points
                /galaxy_camera/image_raw
                /galaxy_camera/camera_info
                /galaxy_camera/image_raw/compressed
                /imu/data
                /imu/mag
                /imu/nav_sat_fix
                /imu/pos_ecef
                /imu/pres
                /imu/temp
                /imu/utc_ref
                /imu/velocity
                /sbg/air_data
                /sbg/ekf_euler
                /sbg/ekf_nav
                /sbg/ekf_quat
                /sbg/gps_pos
                /sbg/gps_vel
                /sbg/imu_data
                /sbg/imu_short
                /sbg/mag
                /sbg/status
                /sbg/utc_time" />
    </group>
</launch>
